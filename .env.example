# Contact form email (Resend) — set these in Vercel → Project → Settings → Environment Variables
# 1. Create an API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where leads are delivered (defaults to info@cheerupdigital.com if unset)
CONTACT_TO_EMAIL=info@cheerupdigital.com

# The "from" address. Before verifying your domain in Resend, leave this unset
# (it defaults to onboarding@resend.dev). After verifying cheerupdigital.com, set:
# CONTACT_FROM_EMAIL=Cheerup Digital <leads@cheerupdigital.com>
CONTACT_FROM_EMAIL=
